flowchart LR
    classDef F fill:#5c8a5c,color:#fff,stroke:none
    classDef C fill:#c87f2a,color:#fff,stroke:none
    classDef D fill:#3a7abf,color:#fff,stroke:none
    classDef E fill:#c0392b,color:#fff,stroke:none
    classDef P fill:#666,color:#fff,stroke:none
    classDef X fill:#888,color:#fff,stroke:2px dashed #ccc

    Nav([Nav]) --> main

    %% ══════════════════════════════════════════
    subgraph A [① 入口導航]
        direction LR
        main["main\nDirectHit / DoNothing"]:::D
        live_home_button["live_home_button\nTemplateMatch: live_home.png → Click"]:::F
        select_live_mode["select_live_mode\nTemplateMatch: freelive.png → Click"]:::F
    end

    %% ══════════════════════════════════════════
    subgraph B [② 選曲]
        direction LR
        select_song["select_song\nOCR: 楽曲選択 / 选择乐曲\npostDelay=1s"]:::F
        random_choice_song["random_choice_song\nTemplateMatch: random_choice_song.png → Click\npost_delay=5s"]:::F
        get_song_name["get_song_name\nCustom: SongRecognition / SaveSongAction\npre_wait_freezes=2s  timeout=5s"]:::C
        set_difficulty["set_difficulty\nCustom: DifficultyRec → Click"]:::C
        comfirm["comfirm\nTemplateMatch: confirm.png → Click\nROI=1153,571,391,149  threshold=0.8"]:::F
    end

    %% ══════════════════════════════════════════
    subgraph C [③ 模式確認]
        direction LR
        ensure_liveboost["ensure_liveboost\nCustom: LiveBoostEnoughRecognition\n/ HandleLiveBoost"]:::C
        ensure_live_mode["ensure_live_mode\nOCR: フリーライブ / チャレンジライブ"]:::F
        switch_liveplay_mode["switch_liveplay_mode\nTemplateMatch: switch_to_live_mode.png\nthreshold=0.9 → Click"]:::F
        exit_rehearsal_mode["exit_rehearsal_mode\nTemplateMatch: exit/pink.png\nor exit/white.png → Click"]:::F
        disable_liveplay["disable_liveplay\nTemplateMatch: liveplay_3d.png / liveplay_mv.png\ninverse=true  ROI=182,585,300,126"]:::F
        toggle_dead["click_liveplay_toggle\nCustom: LivePlayOnRec → Click\n⚠ 孤立節點：JSON 無任何 next 指向"]:::X
    end

    %% ══════════════════════════════════════════
    subgraph D [④ 開始 Live]
        direction LR
        startlive["startlive\nTemplateMatch: startlive.png → Click\npost_delay=2s"]:::F
        wait_live_start["wait_live_start\nTemplateMatch: pause.png\n等待暫停鍵確認 Live 開始"]:::F
    end

    %% ══════════════════════════════════════════
    subgraph E [⑤ Play — scrcpy/HID 自動打歌]
        direction LR
        playsong["playsong\nCustom Action: Play\n呼叫 NavConfig.PlaySong\n① 載入譜面\n② scrcpy/HID 回放觸控事件\n③ 輪詢偵測 live_failed\n④ 阻塞至歌曲結束  timeout=50s\nreturn true=成功 / false=失敗"]:::C
    end

    %% ══════════════════════════════════════════
    subgraph F2 [⑥ 結算]
        direction LR
        wait_playresult["wait_playresult\nTemplateMatch: scored.png / activity_scored.png\npre_wait_freezes={0.65, 5s}  post_delay=3s"]:::F
        wait_playresult1["wait_playresult1\nTemplateMatch: scored.png / activity_scored.png\npre_wait_freezes=2s"]:::F
        save_succeed["save_succeed_playresult\nCustom: PlayResultRecognition / SavePlayResult\nparam: succeed=true\nOCR 讀取分數 / maxCombo / 判定統計"]:::C
    end

    %% ══════════════════════════════════════════
    subgraph G [⑦ 失敗分支]
        direction LR
        live_failed["live_failed\nOCR: ライブ失敗\nROI=406,220,160,62"]:::F
        save_failed["save_failed_playresult\nCustom Action: SavePlayResult\nparam: succeed=false"]:::C
        exit_button["exit_button\nTemplateMatch: exit/pink.png\nor exit/white.png → Click"]:::F
    end

    %% ══ 主線流程 ════════════════════════════════
    main --> live_home_button
    main --> select_live_mode
    main --> select_song

    live_home_button --> select_live_mode
    live_home_button -->|重試| live_home_button
    live_home_button -->|on_error| to_home["to_home → menu_home\nTemplateMatch 回主頁"]:::P

    select_live_mode --> select_song
    select_song --> random_choice_song
    select_song -->|重試| select_song
    select_song --> select_live_mode
    select_song --> live_home_button
    random_choice_song --> get_song_name
    random_choice_song -->|重試| random_choice_song
    get_song_name --> set_difficulty
    set_difficulty --> comfirm
    comfirm --> ensure_liveboost

    ensure_liveboost --> ensure_live_mode
    ensure_live_mode --> disable_liveplay
    ensure_live_mode -->|JB| switch_liveplay_mode
    switch_liveplay_mode --> disable_liveplay
    ensure_liveboost -->|JB| exit_rehearsal_mode
    disable_liveplay --> startlive

    startlive --> wait_live_start
    startlive -->|JB: startlive 自身重試| startlive
    wait_live_start --> playsong

    playsong -->|return true → 成功| wait_playresult
    playsong -->|return false → 失敗 JB| live_failed

    wait_playresult --> wait_playresult1
    wait_playresult1 --> save_succeed
    save_succeed --> live_home_button

    live_failed --> save_failed
    live_failed --> exit_button
    save_failed --> live_home_button
    save_failed -->|JB| exit_button

    %% ══ JumpBack 彈窗處理（共用）══════════════
    live_home_button -->|JB| jb(["JumpBack\nnext_button / close_button"]):::P
    get_song_name -->|JB| jb2(["JumpBack\nconfirm_button"]):::P
    startlive -->|JB| jb3(["JumpBack\nconfirm / login_expired\nconnect_failed"]):::P
    playsong -->|JB| jb4(["JumpBack\nbuttons / login / connect"]):::P
    wait_playresult -->|JB| jb5(["JumpBack\nnext / close / ok / confirm"]):::P
    save_succeed -->|JB| jb6(["JumpBack\nbuttons / reader_menu\nread_after"]):::P
    live_failed -->|JB| jb7(["JumpBack\nlogin_expired\nconnect_failed"]):::P

    %% ══ 圖例 ════════════════════════════════════
    subgraph Legend [圖例]
        direction LR
        lF["TemplateMatch / OCR\n圖像 / 文字辨識"]:::F
        lC["Custom\nGo 自訂辨識 / 動作"]:::C
        lD["DirectHit\n無條件執行"]:::D
        lP["JumpBack\n處理後跳回"]:::P
        lX["⚠ 孤立節點\nJSON 無法到達"]:::X
    end
